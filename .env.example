# Copy to .env and adjust if the defaults conflict with something on your machine.
# Every variable has a safe local default in compose.yaml; this file documents them.

POSTGRES_USER=devflow
POSTGRES_PASSWORD=devflow_local
POSTGRES_DB=devflow
POSTGRES_PORT=5432

REDIS_PORT=6379

# Application database connection (packages/db, drizzle-kit, integration tests).
# The default matches the compose.yaml Postgres above.
DEVFLOW_DATABASE_URL=postgresql://devflow:devflow_local@127.0.0.1:5432/devflow

# Redis connection (BullMQ queue). Default matches the compose.yaml Redis above.
DEVFLOW_REDIS_URL=redis://127.0.0.1:6379

# API server (apps/api). Loopback by default — exposing it is an explicit choice.
DEVFLOW_API_HOST=127.0.0.1
DEVFLOW_API_PORT=3001
DEVFLOW_LOG_LEVEL=info

# Shared secret for GitHub webhook HMAC verification. Required — the API
# refuses to boot without it. Generate one: openssl rand -hex 32
# Must match the "Webhook secret" configured on the GitHub App.
DEVFLOW_GITHUB_WEBHOOK_SECRET=

# GitHub App credentials (apps/worker). Required — the worker refuses to boot
# without them. App ID is on the App's settings page; the private key is
# generated there (M2+) and base64-encoded: base64 -w0 devflow-app.private-key.pem
DEVFLOW_GITHUB_APP_ID=
DEVFLOW_GITHUB_APP_PRIVATE_KEY_BASE64=

# Worker tuning (defaults shown; override only with a reason).
DEVFLOW_WORKER_CONCURRENCY=5
