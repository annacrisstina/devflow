# Copy to .env and adjust if the defaults conflict with something on your machine.
# Every variable has a safe local default in compose.yaml; this file documents them.

POSTGRES_USER=devflow
POSTGRES_PASSWORD=devflow_local
POSTGRES_DB=devflow
POSTGRES_PORT=5432

REDIS_PORT=6379

# Application database connection (packages/db, drizzle-kit, integration tests).
# The default matches the compose.yaml Postgres above.
DEVFLOW_DATABASE_URL=postgresql://devflow:devflow_local@127.0.0.1:5432/devflow
