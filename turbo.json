{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"],
      // Turbo's strict env mode strips undeclared variables from task
      // environments; integration tests need the database URL to reach it.
      "env": ["DEVFLOW_DATABASE_URL"]
    }
  }
}
